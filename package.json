{
  "name": "webview-bridge-kit",
  "version": "0.1.0",
  "description": "Type-safe RPC + pub/sub bridge between a WebView and its React Native host.",
  "license": "MIT",
  "author": "kimyounghee425 <yonghee.kim@intbridge.co.kr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimyounghee425/webview-bridge-kit.git"
  },
  "homepage": "https://github.com/kimyounghee425/webview-bridge-kit#readme",
  "bugs": {
    "url": "https://github.com/kimyounghee425/webview-bridge-kit/issues"
  },
  "keywords": [
    "webview",
    "react-native",
    "bridge",
    "rpc",
    "pub-sub",
    "postmessage",
    "typescript"
  ],
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "import": "./dist/react-native.js",
      "require": "./dist/react-native.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
